# Copy to docker/.env.production on your server and fill in real values.
# Used by: docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build

# --- Domains (DNS A records must point to your server IP) ---
APP_DOMAIN=app.yourdomain.com
API_DOMAIN=api.yourdomain.com

# --- Frontend (baked in at image build time) ---
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# --- Backend ---
CORS_ORIGINS=https://app.yourdomain.com
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
JWT_SECRET=replace-with-a-long-random-secret
OPENAI_API_KEY=
